{
  "openapi": "3.0.3",
  "info": {
    "title": "TodoListApp API",
    "description": "TodoListApp REST API 명세서.\n\n## 인증\n모든 보호된 엔드포인트는 `Authorization: Bearer <token>` 헤더가 필요합니다.\nJWT Access Token은 `POST /api/auth/login` 에서 발급받습니다.\n\n## MVP 범위\n- `POST /api/auth/register` — 회원가입\n- `POST /api/auth/login` — 로그인\n- `GET /api/categories` — 카테고리 목록 조회\n- `GET /api/todos` — 할일 목록 조회 (필터링)\n- `POST /api/todos` — 할일 등록\n- `GET /api/todos/{id}` — 할일 단건 조회\n- `PUT /api/todos/{id}` — 할일 수정\n- `PATCH /api/todos/{id}/complete` — 완료 토글\n- `DELETE /api/todos/{id}` — 할일 삭제\n\n## Post-MVP 범위\n- `GET/PATCH/DELETE /api/users/me` — 사용자 프로필 관리\n- `POST/PATCH/DELETE /api/categories/{id}` — 사용자 정의 카테고리 관리",
    "version": "1.0.0",
    "contact": {
      "name": "TodoListApp"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "로컬 개발 서버"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "회원가입 및 로그인 (인증 불필요)"
    },
    {
      "name": "Categories",
      "description": "카테고리 조회 및 관리"
    },
    {
      "name": "Todos",
      "description": "할일 CRUD 및 완료 처리"
    },
    {
      "name": "Users",
      "description": "사용자 프로필 관리 (Post-MVP)"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "POST /api/auth/login 으로 발급받은 JWT Access Token"
      }
    },
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "required": ["email", "password", "name"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "maxLength": 255,
            "description": "로그인에 사용할 이메일 주소 (시스템 내 유일)",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "description": "비밀번호 (서버에서 bcrypt 해시로 저장)",
            "example": "SecurePass123"
          },
          "name": {
            "type": "string",
            "maxLength": 100,
            "description": "프로필에 표시되는 사용자명",
            "example": "홍길동"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "description": "가입한 이메일 주소",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "format": "password",
            "description": "비밀번호",
            "example": "SecurePass123"
          }
        }
      },
      "UserResponse": {
        "type": "object",
        "required": ["id", "email", "name", "created_at"],
        "properties": {
          "id": {
            "type": "integer",
            "description": "사용자 고유 식별자",
            "example": 1
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "사용자 이메일",
            "example": "user@example.com"
          },
          "name": {
            "type": "string",
            "description": "사용자명",
            "example": "홍길동"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "가입 일시 (ISO 8601)",
            "example": "2026-05-13T10:30:00Z"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "required": ["access_token", "token_type", "user"],
        "properties": {
          "access_token": {
            "type": "string",
            "description": "JWT Access Token. 클라이언트는 Zustand 메모리 스토어에 저장 (localStorage 사용 금지)",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VyX2lkIjoxLCJlbWFpbCI6InVzZXJAZXhhbXBsZS5jb20ifQ.signature"
          },
          "token_type": {
            "type": "string",
            "description": "토큰 타입",
            "enum": ["Bearer"],
            "example": "Bearer"
          },
          "user": {
            "$ref": "#/components/schemas/UserResponse"
          }
        }
      },
      "CategoryResponse": {
        "type": "object",
        "required": ["id", "name", "is_default", "user_id"],
        "properties": {
          "id": {
            "type": "integer",
            "description": "카테고리 고유 식별자",
            "example": 1
          },
          "name": {
            "type": "string",
            "description": "카테고리명",
            "example": "업무"
          },
          "is_default": {
            "type": "boolean",
            "description": "기본 카테고리 여부. true이면 모든 사용자가 사용 가능한 시스템 카테고리",
            "example": true
          },
          "user_id": {
            "type": "integer",
            "nullable": true,
            "description": "카테고리 소유자 ID. null이면 시스템 기본 카테고리",
            "example": null
          }
        }
      },
      "CreateCategoryRequest": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 100,
            "description": "생성할 카테고리명 (동일 사용자 범위 내 중복 불가)",
            "example": "운동"
          }
        }
      },
      "UpdateCategoryRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 100,
            "description": "변경할 카테고리명",
            "example": "헬스"
          }
        }
      },
      "TodoResponse": {
        "type": "object",
        "required": ["id", "user_id", "category_id", "title", "is_completed", "created_at", "updated_at"],
        "properties": {
          "id": {
            "type": "integer",
            "description": "할일 고유 식별자",
            "example": 1
          },
          "user_id": {
            "type": "integer",
            "description": "할일 소유자 사용자 ID",
            "example": 1
          },
          "category_id": {
            "type": "integer",
            "description": "할일이 속한 카테고리 ID",
            "example": 1
          },
          "title": {
            "type": "string",
            "description": "할일 제목",
            "example": "마케팅 전략서 작성"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "할일 상세 설명 (선택사항)",
            "example": "Q1 캠페인 관련 전략 초안 작성"
          },
          "due_date": {
            "type": "string",
            "format": "date",
            "nullable": true,
            "description": "종료예정일 (YYYY-MM-DD, 선택사항)",
            "example": "2026-05-20"
          },
          "is_completed": {
            "type": "boolean",
            "description": "완료 여부. false = 미완료, true = 완료",
            "example": false
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "할일 등록 일시 (ISO 8601)",
            "example": "2026-05-13T10:30:00Z"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "할일 최종 수정 일시 (ISO 8601)",
            "example": "2026-05-13T14:45:00Z"
          }
        }
      },
      "CompleteToggleResponse": {
        "type": "object",
        "required": ["id", "user_id", "category_id", "title", "is_completed", "created_at", "updated_at"],
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "user_id": {
            "type": "integer",
            "example": 1
          },
          "category_id": {
            "type": "integer",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "마케팅 전략서 작성"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "example": "Q1 캠페인 관련 전략 초안 작성"
          },
          "due_date": {
            "type": "string",
            "format": "date",
            "nullable": true,
            "example": "2026-05-20"
          },
          "is_completed": {
            "type": "boolean",
            "description": "토글된 완료 여부 (이전 상태의 반대)",
            "example": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-05-13T10:30:00Z"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "토글 시각으로 갱신",
            "example": "2026-05-13T15:00:00Z"
          }
        }
      },
      "CreateTodoRequest": {
        "type": "object",
        "required": ["title", "category_id"],
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 255,
            "description": "할일 제목 (필수)",
            "example": "마케팅 전략서 작성"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "할일 상세 설명 (선택사항)",
            "example": "Q1 캠페인 관련 전략 초안 작성"
          },
          "due_date": {
            "type": "string",
            "format": "date",
            "nullable": true,
            "description": "종료예정일 (YYYY-MM-DD, 선택사항)",
            "example": "2026-05-20"
          },
          "category_id": {
            "type": "integer",
            "description": "할일이 속할 카테고리 ID (필수, DB에 존재해야 함)",
            "example": 1
          }
        }
      },
      "UpdateTodoRequest": {
        "type": "object",
        "required": ["title", "category_id"],
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 255,
            "description": "수정할 할일 제목 (필수)",
            "example": "마케팅 전략서 작성 (수정)"
          },
          "description": {
            "type": "string",
            "nullable": true,
            "description": "수정할 상세 설명 (선택사항, null 전달 시 제거)",
            "example": "Q2 캠페인으로 범위 변경"
          },
          "due_date": {
            "type": "string",
            "format": "date",
            "nullable": true,
            "description": "수정할 종료예정일 (YYYY-MM-DD, 선택사항, null 전달 시 제거)",
            "example": "2026-05-25"
          },
          "category_id": {
            "type": "integer",
            "description": "수정할 카테고리 ID (필수)",
            "example": 2
          }
        }
      },
      "UpdateUserRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "maxLength": 100,
            "description": "변경할 표시 이름",
            "example": "김철수"
          },
          "password": {
            "type": "string",
            "format": "password",
            "description": "변경할 비밀번호",
            "example": "NewSecurePass456"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error", "message"],
        "properties": {
          "error": {
            "type": "string",
            "description": "에러 코드",
            "example": "VALIDATION_ERROR"
          },
          "message": {
            "type": "string",
            "description": "사람이 읽을 수 있는 에러 메시지",
            "example": "올바른 이메일 형식을 입력하세요."
          }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "인증 토큰 누락 또는 만료",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "error": "UNAUTHORIZED",
              "message": "인증이 필요합니다. 로그인해주세요."
            }
          }
        }
      },
      "Forbidden": {
        "description": "인증은 됐으나 해당 리소스에 대한 접근 권한 없음",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "error": "FORBIDDEN",
              "message": "이 리소스에 접근할 권한이 없습니다."
            }
          }
        }
      },
      "NotFound": {
        "description": "요청한 리소스를 찾을 수 없음",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "error": "NOT_FOUND",
              "message": "요청한 리소스를 찾을 수 없습니다."
            }
          }
        }
      }
    }
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "회원가입",
        "description": "이메일·비밀번호·이름으로 새 계정을 생성합니다.\n\n**비즈니스 규칙**\n- 이메일은 RFC 5322 형식을 준수해야 합니다 (BR-01)\n- 비밀번호는 bcrypt(SALT_ROUNDS≥10)로 해시하여 저장됩니다 (BR-02)\n- 이미 가입된 이메일이면 409를 반환합니다",
        "operationId": "register",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegisterRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "회원가입 성공. 비밀번호는 응답에 포함되지 않습니다.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserResponse" },
                "example": {
                  "id": 1,
                  "email": "user@example.com",
                  "name": "홍길동",
                  "created_at": "2026-05-13T10:30:00Z"
                }
              }
            }
          },
          "400": {
            "description": "요청 형식 오류 (필드 누락, 이메일 형식 불일치 등)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "error": "VALIDATION_ERROR",
                  "message": "올바른 이메일 형식을 입력하세요."
                }
              }
            }
          },
          "409": {
            "description": "이미 가입된 이메일",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "error": "EMAIL_CONFLICT",
                  "message": "이미 가입된 이메일입니다. 로그인하거나 다른 이메일을 사용해주세요."
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "로그인 및 JWT 발급",
        "description": "이메일·비밀번호로 로그인하고 JWT Access Token을 발급합니다.\n\n**비즈니스 규칙**\n- 이메일 미존재 및 비밀번호 불일치 모두 동일하게 401을 반환합니다 (이메일 존재 여부 노출 방지, BR-03)\n- 발급된 토큰은 클라이언트의 Zustand 메모리 스토어에 저장해야 합니다 (localStorage 사용 금지)",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "로그인 성공. access_token을 Zustand 메모리에 저장하세요.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/LoginResponse" },
                "example": {
                  "access_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VyX2lkIjoxLCJlbWFpbCI6InVzZXJAZXhhbXBsZS5jb20ifQ.signature",
                  "token_type": "Bearer",
                  "user": {
                    "id": 1,
                    "email": "user@example.com",
                    "name": "홍길동",
                    "created_at": "2026-05-13T10:30:00Z"
                  }
                }
              }
            }
          },
          "400": {
            "description": "요청 형식 오류 (필드 누락 등)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "error": "VALIDATION_ERROR",
                  "message": "이메일과 비밀번호를 입력해주세요."
                }
              }
            }
          },
          "401": {
            "description": "인증 실패 (이메일 미존재 또는 비밀번호 불일치)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "error": "UNAUTHORIZED",
                  "message": "이메일 또는 비밀번호가 잘못되었습니다."
                }
              }
            }
          }
        }
      }
    },
    "/api/categories": {
      "get": {
        "tags": ["Categories"],
        "summary": "카테고리 목록 조회",
        "description": "기본 카테고리(시스템 제공) + 로그인 사용자의 사용자 정의 카테고리를 함께 반환합니다.\n기본 카테고리가 목록 상단에 먼저 나옵니다.\n\n**기본 카테고리 예시**: 업무, 개인, 쇼핑, 기타",
        "operationId": "getCategories",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "카테고리 목록 조회 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["data"],
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/CategoryResponse" }
                    }
                  }
                },
                "example": {
                  "data": [
                    { "id": 1, "name": "업무", "is_default": true, "user_id": null },
                    { "id": 2, "name": "개인", "is_default": true, "user_id": null },
                    { "id": 3, "name": "쇼핑", "is_default": true, "user_id": null },
                    { "id": 4, "name": "기타", "is_default": true, "user_id": null },
                    { "id": 5, "name": "운동", "is_default": false, "user_id": 1 }
                  ]
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["Categories"],
        "summary": "사용자 정의 카테고리 생성 (Post-MVP)",
        "description": "로그인 사용자의 새 카테고리를 생성합니다.\n\n**비즈니스 규칙**\n- 동일 사용자 범위 내에서 카테고리명 중복 불가 (BR-06)\n- 기본 카테고리와 동일한 이름도 사용 불가",
        "operationId": "createCategory",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateCategoryRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "카테고리 생성 성공",
