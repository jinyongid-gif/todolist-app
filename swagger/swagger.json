    "/api/todos": {
      "get": {
        "tags": ["Todos"],
        "summary": "할일 목록 조회",
        "description": "로그인 사용자의 할일 목록을 조회합니다. 쿼리 파라미터로 복합 필터링이 가능합니다.\n\n**기본 정렬**: `created_at DESC` (등록일 최신순)\n\n**기간 초과 판별**: `due_date < CURRENT_DATE AND is_completed = FALSE`",
        "operationId": "getTodos",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "category_id",
            "in": "query",
            "required": false,
            "schema": { "type": "integer" },
            "description": "카테고리 ID로 필터링",
            "example": 1
          },
          {
            "name": "is_completed",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean" },
            "description": "완료 여부로 필터링. true=완료만, false=미완료만. 생략 시 전체",
            "example": false
          },
          {
            "name": "overdue",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean" },
            "description": "기간 초과 필터. true이면 due_date < CURRENT_DATE AND is_completed=FALSE 인 항목만 반환",
            "example": true
          }
        ],
        "responses": {
          "200": {
            "description": "할일 목록 조회 성공",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["data"],
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/TodoResponse" }
                    }
                  }
                },
                "example": {
                  "data": [
                    {
                      "id": 2,
                      "user_id": 1,
                      "category_id": 1,
                      "title": "마케팅 전략서 작성",
                      "description": "Q1 캠페인 관련 전략 초안 작성",
                      "due_date": "2026-05-20",
                      "is_completed": false,
                      "created_at": "2026-05-13T10:30:00Z",
                      "updated_at": "2026-05-13T10:30:00Z"
                    },
                    {
                      "id": 1,
                      "user_id": 1,
                      "category_id": 2,
                      "title": "선형대수 5장 연습문제",
                      "description": null,
                      "due_date": "2026-05-08",
                      "is_completed": false,
                      "created_at": "2026-05-10T09:00:00Z",
                      "updated_at": "2026-05-10T09:00:00Z"
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "쿼리 파라미터 형식 오류",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["Todos"],
        "summary": "할일 등록",
        "description": "새 할일을 등록합니다.\n\n**비즈니스 규칙**\n- `title`과 `category_id`는 필수입니다 (BR-07, BR-08)\n- `category_id`는 DB에 존재하는 값이어야 합니다\n- `due_date`는 `YYYY-MM-DD` 형식이어야 합니다",
        "operationId": "createTodo",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateTodoRequest" },
              "example": {
                "title": "마케팅 전략서 작성",
                "description": "Q1 캠페인 관련 전략 초안 작성",
                "due_date": "2026-05-20",
                "category_id": 1
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "할일 등록 성공",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/TodoResponse" },
                "example": {
                  "id": 1,
                  "user_id": 1,
                  "category_id": 1,
                  "title": "마케팅 전략서 작성",
                  "description": "Q1 캠페인 관련 전략 초안 작성",
                  "due_date": "2026-05-20",
                  "is_completed": false,
                  "created_at": "2026-05-13T10:30:00Z",
                  "updated_at": "2026-05-13T10:30:00Z"
                }
              }
            }
          },
          "400": {
            "description": "요청 형식 오류 (title 누락, due_date 형식 오류 등)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "error": "VALIDATION_ERROR",
                  "message": "할일 제목을 입력해주세요."
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": {
            "description": "카테고리 미존재",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" },
                "example": {
                  "error": "NOT_FOUND",
                  "message": "유효하지 않은 카테고리입니다."
                }
              }
            }
          }
        }
      }
    },
